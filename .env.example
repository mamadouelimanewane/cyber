# ── Gravity Security — Configuration d'environnement ──────────────────────────
# Copier ce fichier en .env et adapter les valeurs
# cp .env.example .env

# ──────────────────────────────────────────────────────────────────────────────
# SECRETS (OBLIGATOIRE: changer en production)
# ──────────────────────────────────────────────────────────────────────────────
DB_PASSWORD=GravityDB_SecurePass_2026!
SHARED_SECRET=gravity-security-secret-change-me-in-production
GRAFANA_PASSWORD=GravityGrafana2026!
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gravity
DB_USER=gravity

# ──────────────────────────────────────────────────────────────────────────────
# SERVEUR CENTRAL
# ──────────────────────────────────────────────────────────────────────────────
SERVER_WORKERS=4
SERVER_PORT=8000
SERVER_HOST=0.0.0.0

# ──────────────────────────────────────────────────────────────────────────────
# COLLECTOR RÉGIONAL
# ──────────────────────────────────────────────────────────────────────────────
COLLECTOR_FLUSH_INTERVAL=3
COLLECTOR_MAX_AGENTS=500
COLLECTOR_MIN_SEVERITY=low

# ──────────────────────────────────────────────────────────────────────────────
# SIMULATEUR DE CHARGE (profil loadtest)
# ──────────────────────────────────────────────────────────────────────────────
SIM_AGENTS=100
SIM_RATE=10

# ──────────────────────────────────────────────────────────────────────────────
# RÉPONSE AUX INCIDENTS
# ──────────────────────────────────────────────────────────────────────────────
INCIDENT_WEBHOOK_URL=
INCIDENT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# CONSOLE WEB
# ──────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
