FROM python:3.12-slim

WORKDIR /app

COPY agent/src/ ./agent/src/
COPY demo/load_simulator.py ./

ENV PYTHONPATH=/app/agent/src
ENV NUM_AGENTS=100
ENV ALERTS_PER_MIN=10
ENV COLLECTOR_URL=http://collector-lb:8001
ENV SHARED_SECRET=gravity-security-secret-change-me
ENV PYTHONUNBUFFERED=1

CMD python load_simulator.py \
    --agents ${NUM_AGENTS} \
    --target ${COLLECTOR_URL} \
    --rate ${ALERTS_PER_MIN} \
    --secret ${SHARED_SECRET}
